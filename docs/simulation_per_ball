       - dew_factor: float (venue-specific moisture/ball condition effect)
       - partnership_runs: int (runs in current partnership)
       - batsman_fatigue: float (0-1)
       - bowler_fatigue: float (0-1)

       Player Context (7 fields):
       - is_batsman_home: bool (home advantage for batsman)
       - is_bowler_home: bool (home advantage for bowler)
       - bowler_economy: float (career runs per over)
       - bowler_bowling_avg: float (career average)
       - bowler_death_spec: float (death bowling specialization 0-1)
       - bowler_style: str (e.g., "pace", "off_break", "left_arm_spin")
       - match_index: int (match sequencing for expectation tax)

       Strategy & Game State (10 additional fields):
       - is_post_timeout: bool (intent shift post strategic timeout)
       - is_17th_over: bool (death leverage point)
       - captain_defensive_tendency: float (0-1, field spread)
       - batting_collapse_active: bool (2 wickets in 6 balls contagion)
       - anchor_penalty_active: bool (partner batting slow → this batter forced to hit)
       - franchise_clutch_factor: float (0.5 baseline; high for CSK/MI)
       - fielding_conversion_probability: float (catch drop variance)
       - lower_order_strike_independence: bool (bowlers batting freely)
       - over_rate_pressure_active: bool (final 2 overs field restrictions)
       - field_state: FieldState | None (on-field fielding positions)

