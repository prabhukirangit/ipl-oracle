# =============================================================
# IPL Oracle — Environment Variables
# =============================================================
# Copy to .env and fill in your values.
# Supports cloud providers (Anthropic, OpenAI, Gemini) OR
# fully offline mode with Ollama / LM Studio / vLLM.
# =============================================================

# -----------------------------------------------------------------------
# LLM Provider — pick ONE provider and set its key(s)
# -----------------------------------------------------------------------
# Which provider to use: anthropic | openai | gemini | local
# If not set, auto-detected from whichever key is present (anthropic first).
LLM_PROVIDER=anthropic

# Global model override (takes precedence over per-provider models below).
# Leave blank to use the per-provider default.
# LLM_MODEL=

# -----------------------------------------------------------------------
# Cloud Providers — set keys for the ones you use
# -----------------------------------------------------------------------
# You can have multiple keys present and switch providers by changing
# LLM_PROVIDER above. Each provider reads its own *_MODEL override;
# if blank, falls back to the default shown in the comment.

# Anthropic (default provider)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4o

# Google Gemini
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.0-flash

# -----------------------------------------------------------------------
# Fully Offline Mode — Ollama / LM Studio / vLLM
# -----------------------------------------------------------------------
# To run completely offline with no cloud API calls:
#   1. Install Ollama: https://ollama.com/download
#   2. Pull a model: ollama pull qwen2.5:14b
#   3. Set LLM_PROVIDER=local below and uncomment the LOCAL_LLM_* lines
#
# Recommended models (by VRAM):
#   24GB+ VRAM → qwen2.5:32b  (best quality)
#   10-16GB    → qwen2.5:14b  or llama3.2:latest
#   8GB        → qwen2.5:7b   or mistral:7b
#   CPU-only   → qwen2.5:3b   (fastest, lower quality)
#
# For Docker: use service name "ollama" instead of "localhost"
#   LOCAL_LLM_BASE_URL=http://ollama:11434/v1
#
# LLM_PROVIDER=local
# LOCAL_LLM_BASE_URL=http://localhost:11434/v1
# LOCAL_LLM_API_KEY=ollama
# LOCAL_LLM_MODEL=qwen2.5:14b

# -----------------------------------------------------------------------
# Simulation Settings
# -----------------------------------------------------------------------

# Default simulation count (per-mode defaults: persona=10, hybrid=10, probabilistic=500)
DEFAULT_SIM_COUNT=10

# Max parallel batch size
MAX_PARALLEL_SIMS=25

# Hybrid mode: LLM fires when pressure >= this threshold
LLM_PRESSURE_THRESHOLD=0.65

# Rate limiting: prevent 429 errors from LLM providers
LLM_MAX_CONCURRENT=5
LLM_MIN_DELAY_MS=200

# Persona mode LLM trigger granularity (only applies to persona mode):
#   per_over   — 2 LLM calls per over (batch plan). Default. Best balance.
#   per_ball   — 2 LLM calls per ball (12/over). Max fidelity, highest cost.
#   per_wicket — LLM only on wicket falls + first over. Cheapest persona mode.
PERSONA_LLM_TRIGGER=per_over

# -----------------------------------------------------------------------
# Weather Data — Free tier: 1000 calls/day (openweathermap.org)
# -----------------------------------------------------------------------
OPENWEATHERMAP_API_KEY=your_key_here

# -----------------------------------------------------------------------
# Agent Memory — Mem0 OSS (self-hosted, free). Only set for Mem0 Cloud.
# -----------------------------------------------------------------------
# MEM0_API_KEY=optional_cloud_key

# -----------------------------------------------------------------------
# News Search — Optional. Leave blank to use free Google News RSS.
# -----------------------------------------------------------------------
# SERPAPI_KEY=optional_only_if_rss_proves_unreliable

# -----------------------------------------------------------------------
# App Settings
# -----------------------------------------------------------------------
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_URL=http://localhost:5173
