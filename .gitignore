# .gitignore for IPL Oracle

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
.Python
env/
venv/
.venv/
venv*/
pip-wheel-metadata/
*.egg-info/
dist/
build/
*.egg
.pytest_cache/
.coverage
htmlcov/

# ---- Playwright / browser cache ----
.cache/
playwright/.local-browsers/

# ---- Node / Frontend ----
node_modules/
frontend/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
frontend/dist/

# ---- IDEs & Editors ----
.vscode/
.idea/

# ---- OS files ----
.DS_Store
Thumbs.db

# ---- Logs & runtime ----
logs/
*.log

# ---- Environment & secrets ----
.env
*.pem
*.key

# ---- Docker / compose overrides ----
docker-compose.override.yml
# Environment — never commit
.env
*.env

# Python
__pycache__/
*.pyc
*.pyo
.venv/
.uv/
dist/
*.egg-info/

# Node
node_modules/
frontend/dist/

# Data / DB
backend/data/
*.kuzu/

# OS
.DS_Store
Thumbs.db

# ---- CatBoost model artifacts & training cache ----
backend/app/ml/models/*.cbm
backend/app/ml/models/*.cbm.meta
catboost_info/

# ---- Dataset (large CSV files) ----
Dataset/

# ---- Simulation results (local output) ----
results/

# ---- Claude Code local settings ----
.claude/

#md files
# ---- Root markdown files: ignore all root .md except README.md ----
/*.md
!/README.md

# Specific historical file exceptions (kept for clarity; already covered by rule)
# VERIFICATION_REPORT.md  # covered by /*.md

